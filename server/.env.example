# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB)
# Replace with your MongoDB Atlas URI for production
MONGO_URI=mongodb://localhost:27017/smart-leads

# JWT Secret Key (REQUIRED in production)
# Use a strong, random 64-character hex string: openssl rand -hex 32
JWT_SECRET=

# CORS Origin (the frontend URL allowed to access the API)
CORS_ORIGIN=http://localhost:80

# Admin Seed (optional — set these to create a default admin on first run)
ADMIN_EMAIL=admin@servicehive.com
ADMIN_PASSWORD=
